<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<title>Soils Worksheet Generator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/docx/8.5.0/docx.umd.min.js"></script>
<style>
  body{font-family:Arial,sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;background:#f0f4f8;}
  .card{background:#fff;border-radius:12px;padding:40px;box-shadow:0 4px 20px rgba(0,0,0,.12);max-width:480px;width:100%;text-align:center;}
  h1{color:#2d6a2d;font-size:1.5rem;margin-bottom:6px;}
  p{color:#555;font-size:.95rem;margin-bottom:24px;}
  button{background:#2d6a2d;color:#fff;border:none;padding:14px 32px;border-radius:8px;font-size:1rem;cursor:pointer;transition:background .2s;}
  button:hover{background:#1e4d1e;}
  .badge{display:inline-block;background:#e8f5e9;color:#2d6a2d;border-radius:20px;padding:4px 14px;font-size:.82rem;margin:3px;}
  .badges{margin-bottom:20px;}
</style>
</head>
<body>
<div class="card">
  <h1>🌱 Soils in the Environment</h1>
  <p>Grade 3 Science · Complete Worksheet Package</p>
  <div class="badges">
    <span class="badge">E1.1 Why Soil is Important</span>
    <span class="badge">E1.2 What is Soil Made Of?</span>
    <span class="badge">E2.1 Types of Soil</span>
    <span class="badge">E2.2 Soil and Living Things</span>
    <span class="badge">E2.3 Soil and Water</span>
    <span class="badge">E2.4 Protecting Our Soil</span>
  </div>
  <button onclick="generate()">⬇️ Download Worksheet Package (.docx)</button>
  <p id="status" style="margin-top:14px;color:#2d6a2d;font-weight:bold;"></p>
</div>

<script>
const { Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell, WidthType, BorderStyle, AlignmentType, HeadingLevel, ShadingType, UnderlineType } = docx;

function border(color="#000000",sz=6){return{style:BorderStyle.SINGLE,size:sz,color};}
function noBorder(){return{style:BorderStyle.NONE,size:0,color:"FFFFFF"};}

function hCell(text,bg="2d6a2d",w=50){
  return new TableCell({
    width:{size:w,type:WidthType.PERCENTAGE},
    shading:{type:ShadingType.SOLID,color:bg},
    borders:{top:border(),bottom:border(),left:border(),right:border()},
    children:[new Paragraph({alignment:AlignmentType.CENTER,children:[new TextRun({text,bold:true,color:"FFFFFF",size:22})]})]
  });
}
function dCell(text,w=50,minH=600){
  return new TableCell({
    width:{size:w,type:WidthType.PERCENTAGE},
    borders:{top:border(),bottom:border(),left:border(),right:border()},
    margins:{top:100,bottom:minH,left:120,right:120},
    children:[new Paragraph({children:[new TextRun({text,size:22})]})]
  });
}
function emptyCell(w=50,h=800){
  return new TableCell({
    width:{size:w,type:WidthType.PERCENTAGE},
    borders:{top:border(),bottom:border(),left:border(),right:border()},
    margins:{top:100,bottom:h,left:120,right:120},
    children:[new Paragraph({children:[new TextRun({text:"",size:22})]})]
  });
}

function titleBox(emoji,title,subtitle){
  return new Table({
    width:{size:100,type:WidthType.PERCENTAGE},
    rows:[new TableRow({children:[new TableCell({
      shading:{type:ShadingType.SOLID,color:"2d6a2d"},
      borders:{top:border("2d6a2d"),bottom:border("2d6a2d"),left:border("2d6a2d"),right:border("2d6a2d")},
      children:[
        new Paragraph({alignment:AlignmentType.CENTER,children:[new TextRun({text:`${emoji} ${title}`,bold:true,color:"FFFFFF",size:32})]}),
        new Paragraph({alignment:AlignmentType.CENTER,children:[new TextRun({text:subtitle,color:"FFFFFF",size:20})]})
      ]
    })]})],
  });
}

function nameDate(){
  return new Table({
    width:{size:100,type:WidthType.PERCENTAGE},
    rows:[new TableRow({children:[
      new TableCell({width:{size:50,type:WidthType.PERCENTAGE},borders:{top:noBorder(),bottom:noBorder(),left:noBorder(),right:noBorder()},children:[new Paragraph({children:[new TextRun({text:"Name: _______________________________",size:22})]})] }),
      new TableCell({width:{size:50,type:WidthType.PERCENTAGE},borders:{top:noBorder(),bottom:noBorder(),left:noBorder(),right:noBorder()},children:[new Paragraph({children:[new TextRun({text:"Date: ________________",size:22})]})] }),
    ]})],
  });
}

function sectionHeader(emoji,text){
  return new Paragraph({spacing:{before:240,after:120},children:[new TextRun({text:`${emoji} ${text}`,bold:true,size:24,color:"2d6a2d"})]});
}

function wordBank(words){
  return new Table({
    width:{size:100,type:WidthType.PERCENTAGE},
    rows:[new TableRow({children:[new TableCell({
      shading:{type:ShadingType.SOLID,color:"e8f5e9"},
      borders:{top:border("2d6a2d"),bottom:border("2d6a2d"),left:border("2d6a2d"),right:border("2d6a2d")},
      children:[new Paragraph({children:[new TextRun({text:`Word Bank: ${words}`,italics:true,size:20,color:"1e4d1e"})]})]
    })]})],
  });
}

function vocabTable(pairs){
  const rows=[new TableRow({children:[hCell("Word",undefined,50),hCell("Definition",undefined,50)]})];
  pairs.forEach(([w,d])=>rows.push(new TableRow({children:[
    dCell(w,50,300),
    dCell(d,50,300)
  ]})));
  return new Table({width:{size:100,type:WidthType.PERCENTAGE},rows});
}

function sortTable(left,right,items1,items2){
  const rows=[new TableRow({children:[hCell(left,undefined,50),hCell(right,undefined,50)]})];
  const max=Math.max(items1.length,items2.length,4);
  for(let i=0;i<max;i++){
    rows.push(new TableRow({children:[
      dCell(i<items1.length?items1[i]:"",50,320),
      dCell(i<items2.length?items2[i]:"",50,320)
    ]}));
  }
  return new Table({width:{size:100,type:WidthType.PERCENTAGE},rows});
}

function thinkBox(prompt){
  return new Table({
    width:{size:100,type:WidthType.PERCENTAGE},
    rows:[
      new TableRow({children:[new TableCell({
        shading:{type:ShadingType.SOLID,color:"fff9c4"},
        borders:{top:border("f9a825"),bottom:border("f9a825"),left:border("f9a825"),right:border("f9a825")},
        children:[new Paragraph({children:[new TextRun({text:prompt,italics:true,size:20})]})]
      })]}),
      new TableRow({children:[new TableCell({
        borders:{top:border(),bottom:border(),left:border(),right:border()},
        margins:{top:80,bottom:900,left:120,right:120},
        children:[new Paragraph({children:[new TextRun({text:"",size:22})]})]
      })]}),
    ],
  });
}

function fillBlanks(questions){
  return questions.map((q,i)=>new Paragraph({spacing:{before:140,after:60},children:[new TextRun({text:`${i+1}. ${q}`,size:22})]}));
}

function answerRow(left,right){
  return new TableRow({children:[
    dCell(left,50,60),
    dCell(right,50,60)
  ]});
}

// ─── PAGE BREAK ───
function pb(){return new Paragraph({pageBreakBefore:true,children:[new TextRun({text:""})]});}
function sp(n=160){return new Paragraph({spacing:{before:n},children:[new TextRun({text:""})]});}

async function generate(){
  document.getElementById("status").textContent="Building document…";

  // ══════════════════════════════════════════
  // COVER PAGE
  // ══════════════════════════════════════════
  const cover=[
    new Table({width:{size:100,type:WidthType.PERCENTAGE},rows:[new TableRow({children:[new TableCell({
      shading:{type:ShadingType.SOLID,color:"2d6a2d"},
      borders:{top:border("2d6a2d"),bottom:border("2d6a2d"),left:border("2d6a2d"),right:border("2d6a2d")},
      margins:{top:300,bottom:300},
      children:[
        new Paragraph({alignment:AlignmentType.CENTER,children:[new TextRun({text:"🌱 Soils in the Environment",bold:true,color:"FFFFFF",size:48})]}),
        new Paragraph({alignment:AlignmentType.CENTER,children:[new TextRun({text:"Grade 3 Science – Unit E  |  Complete Worksheet Package",color:"FFFFFF",size:24})]}),
      ]
    })]})]}),
    sp(200),
    new Table({width:{size:100,type:WidthType.PERCENTAGE},rows:[
      new TableRow({children:[hCell("E1.1","4a7c4a",50),hCell("E1.2","4a7c4a",50)]}),
      new TableRow({children:[dCell("Why Soil is Important",50,200),dCell("What is Soil Made Of?",50,200)]}),
      new TableRow({children:[hCell("E2.1","4a7c4a",50),hCell("E2.2","4a7c4a",50)]}),
      new TableRow({children:[dCell("Types of Soil",50,200),dCell("Soil and Living Things",50,200)]}),
      new TableRow({children:[hCell("E2.3","4a7c4a",50),hCell("E2.4","4a7c4a",50)]}),
      new TableRow({children:[dCell("Soil and Water",50,200),dCell("Protecting Our Soil",50,200)]}),
    ]}),
    sp(300),
    new Paragraph({children:[new TextRun({text:"Name: _______________________________________________",size:24})]}),
    sp(80),
    new Paragraph({children:[new TextRun({text:"Class: ____________________",size:24})]}),
  ];

  // ══════════════════════════════════════════
  // E1.1 – WHY SOIL IS IMPORTANT
  // ══════════════════════════════════════════
  const e11=[
    pb(),
    titleBox("🌍","Why Soil is Important","E1.1 | Grade 3 Science"),
    sp(80), nameDate(), sp(120),

    sectionHeader("📝","Vocabulary Match – Draw a line to connect each word to its meaning."),
    vocabTable([
      ["Soil","All people living together in communities and towns"],
      ["Society","All the natural things around us including plants, animals, air, and water"],
      ["Environment","The top layer of the Earth where plants grow"],
      ["Oxygen","A gas released by plants that we need to breathe"],
      ["Filter","To clean a liquid by passing it through something"],
    ]),
    sp(160),

    sectionHeader("✏️","Fill in the Blank"),
    wordBank("soil | society | environment | oxygen | sponge"),
    sp(80),
    ...fillBlanks([
      "_____________ is the top layer of the Earth where plants grow.",
      "_____________ means all the people living together in communities, towns, and cities.",
      "The _____________ means all the natural things around us including plants, animals, air, and water.",
      "Plants that grow in soil give us _____________ to breathe.",
      "Healthy soil acts like a big _____________ that soaks up rainwater.",
    ]),
    sp(160),

    sectionHeader("🗂️","Sort It! Write each item in the correct box."),
    wordBank("Grows food for people | Provides oxygen through plants | Place to build homes | Home for worms and insects | Filters and cleans water | Grows cotton for clothes"),
    sp(80),
    sortTable(
      "👥 Helps Society (People)",
      "🌍 Helps the Environment (Nature)",
      [],[]),
    sp(160),

    sectionHeader("💡","Think About It"),
    thinkBox("Name TWO ways soil helps people every day. Use the word 'society' in your answer."),
  ];

  // ══════════════════════════════════════════
  // E1.2 – WHAT IS SOIL MADE OF?
  // ══════════════════════════════════════════
  const e12=[
    pb(),
    titleBox("🔬","What is Soil Made Of?","E1.2 | Grade 3 Science"),
    sp(80), nameDate(), sp(120),

    sectionHeader("📝","Vocabulary Match"),
    vocabTable([
      ["Minerals","Tiny living things too small to see with the naked eye"],
      ["Humus","Broken-down pieces of tiny rock that give soil nutrients"],
      ["Microorganisms","Dead and decaying plant and animal material in soil"],
      ["Pores","Small spaces in soil that hold air and water"],
      ["Decompose","To break down into simpler materials"],
    ]),
    sp(160),

    sectionHeader("✏️","Fill in the Blank"),
    wordBank("humus | minerals | water | air | microorganisms"),
    sp(80),
    ...fillBlanks([
      "Soil is made up of tiny pieces of rock called _____________.",
      "Dead and decayed plant and animal material in soil is called _____________.",
      "The tiny spaces in soil hold _____________ and _____________ that plants need to grow.",
      "_____________ are tiny living things in soil that help break down dead material.",
      "_____________ and minerals are two important parts of soil that help plants grow.",
    ]),
    sp(160),

    sectionHeader("🗂️","Sort It! Write each item in the correct box."),
    wordBank("Tiny pieces of rock | Dead leaves and animals | Worms | Water | Air pockets | Minerals | Bacteria | Sand grains"),
    sp(80),
    sortTable(
      "🪨 Non-Living Parts of Soil",
      "🐛 Living Parts of Soil",
      [],[]),
    sp(160),

    sectionHeader("💡","Think About It"),
    thinkBox("Why do plants need more than just water to grow? Describe TWO things in soil that help plants survive."),
  ];

  // ══════════════════════════════════════════
  // E2.1 – TYPES OF SOIL
  // ══════════════════════════════════════════
  const e21=[
    pb(),
    titleBox("🟤","Types of Soil","E2.1 | Grade 3 Science"),
    sp(80), nameDate(), sp(120),

    sectionHeader("📝","Vocabulary Match"),
    vocabTable([
      ["Clay soil","A type of soil with large particles that drains water quickly"],
      ["Sandy soil","A type of soil with tiny particles that holds water and gets sticky when wet"],
      ["Loam","A mixture of sand, silt, and clay — the best soil for growing plants"],
      ["Texture","How a material feels when you touch it"],
      ["Drainage","How quickly water moves through soil"],
    ]),
    sp(160),

    sectionHeader("✏️","Fill in the Blank"),
    wordBank("clay | sandy | loam | texture | drainage"),
    sp(80),
    ...fillBlanks([
      "_____________ soil has tiny particles and gets sticky and hard when it dries.",
      "_____________ soil has large particles and lets water pass through very quickly.",
      "_____________ is the best type of soil for growing plants because it holds just enough water.",
      "The _____________ of soil tells us how it feels — rough, smooth, or sticky.",
      "Good _____________ means water flows through soil at just the right speed for plant roots.",
    ]),
    sp(160),

    sectionHeader("🗂️","Sort It!"),
    wordBank("Holds water well | Drains too fast | Sticky when wet | Feels gritty | Best for growing plants | Cracks when dry | Good mix of particles | Lets water run right through"),
    sp(80),
    new Table({width:{size:100,type:WidthType.PERCENTAGE},rows:[
      new TableRow({children:[hCell("🟤 Clay Soil",undefined,33),hCell("🏖️ Sandy Soil",undefined,34),hCell("🌱 Loam",undefined,33)]}),
      new TableRow({children:[emptyCell(33,800),emptyCell(34,800),emptyCell(33,800)]}),
    ]}),
    sp(160),

    sectionHeader("💡","Think About It"),
    thinkBox("A farmer wants to grow carrots. Which type of soil would you recommend? Explain why using the words 'drainage' and 'texture'."),
  ];

  // ══════════════════════════════════════════
  // E2.2 – SOIL AND LIVING THINGS
  // ══════════════════════════════════════════
  const e22=[
    pb(),
    titleBox("🐛","Soil and Living Things","E2.2 | Grade 3 Science"),
    sp(80), nameDate(), sp(120),

    sectionHeader("📝","Vocabulary Match"),
    vocabTable([
      ["Decomposer","An animal that digs through soil, mixing and aerating it"],
      ["Earthworm","An organism that breaks down dead material into nutrients"],
      ["Nutrient","A substance that living things need to grow and stay healthy"],
      ["Aerate","To add air into soil by mixing or turning it"],
      ["Habitat","A place where plants and animals live and find what they need"],
    ]),
    sp(160),

    sectionHeader("✏️","Fill in the Blank"),
    wordBank("earthworms | nutrients | decomposers | habitat | aerate"),
    sp(80),
    ...fillBlanks([
      "_____________ tunnel through soil, which helps mix it and let air in.",
      "Bacteria and fungi are _____________ — they break down dead things into nutrients.",
      "When decomposers break down dead material, they release _____________ that plants can use.",
      "_____________ means adding air into soil so plant roots can breathe.",
      "Soil provides a _____________ for millions of living things including insects, worms, and fungi.",
    ]),
    sp(160),

    sectionHeader("🗂️","Sort It!"),
    wordBank("Earthworm | Oak tree | Mushroom | Robin | Bacteria | Grass | Beetle | Dandelion"),
    sp(80),
    sortTable(
      "🌱 Plants (grow IN soil)",
      "🐛 Animals & Decomposers (live IN soil)",
      [],[]),
    sp(160),

    sectionHeader("🎨","Draw & Label"),
    new Table({width:{size:100,type:WidthType.PERCENTAGE},rows:[
      new TableRow({children:[new TableCell({
        borders:{top:border(),bottom:border(),left:border(),right:border()},
        margins:{top:80,bottom:1800,left:120,right:120},
        children:[new Paragraph({children:[new TextRun({text:"Draw a cross-section of soil showing at least THREE living things. Label what each creature does for the soil.",italics:true,size:20})]})]
      })]}),
    ]}),
  ];

  // ══════════════════════════════════════════
  // E2.3 – SOIL AND WATER
  // ══════════════════════════════════════════
  const e23=[
    pb(),
    titleBox("💧","Soil and Water","E2.3 | Grade 3 Science"),
    sp(80), nameDate(), sp(120),

    sectionHeader("📝","Vocabulary Match"),
    vocabTable([
      ["Absorption","The wearing away of soil by wind or water"],
      ["Erosion","When soil soaks up and holds water"],
      ["Runoff","The movement of water over the surface of the ground"],
      ["Permeability","How easily water can move through soil"],
      ["Flooding","When too much water covers land that is normally dry"],
    ]),
    sp(160),

    sectionHeader("✏️","Fill in the Blank"),
    wordBank("erosion | absorption | runoff | flooding | permeability"),
    sp(80),
    ...fillBlanks([
      "_____________ is the wearing away of soil by wind or water.",
      "When soil soaks up rainwater, it is called _____________.",
      "Water that flows over the ground instead of soaking in is called _____________.",
      "_____________ describes how easily water can move through soil.",
      "Healthy soil that absorbs water well can help prevent _____________.",
    ]),
    sp(160),

    sectionHeader("✅","True or False – Circle T or F."),
    new Table({width:{size:100,type:WidthType.PERCENTAGE},rows:[
      new TableRow({children:[hCell("T / F",undefined,15),hCell("Statement",undefined,85)]}),
      ...["Sandy soil absorbs water more slowly than clay soil.",
          "Soil with lots of organic matter can hold more water.",
          "Erosion is when soil is worn away by wind or water.",
          "Plants help prevent soil erosion by holding soil in place with their roots.",
          "Water runoff is good for preventing flooding.",
      ].map(s=>new TableRow({children:[
        dCell("T     F",15,100),
        dCell(s,85,100)
      ]}))
    ]}),
    sp(160),

    sectionHeader("💡","Think About It"),
    thinkBox("Why do farmers plant crops or grasses on hillsides? How does this help prevent erosion? Use the words 'roots' and 'runoff' in your answer."),
  ];

  // ══════════════════════════════════════════
  // E2.4 – PROTECTING OUR SOIL
  // ══════════════════════════════════════════
  const e24=[
    pb(),
    titleBox("♻️","Protecting Our Soil","E2.4 | Grade 3 Science"),
    sp(80), nameDate(), sp(120),

    sectionHeader("📝","Vocabulary Match"),
    vocabTable([
      ["Compost","The practice of rotating different crops each year to keep soil healthy"],
      ["Crop rotation","A mixture of decayed food scraps and plant material added to soil"],
      ["Contamination","When harmful chemicals or substances get into soil"],
      ["Conservation","Protecting natural resources so they are not used up or damaged"],
      ["Sustainable","Using resources in a way that can continue long into the future"],
    ]),
    sp(160),

    sectionHeader("✏️","Fill in the Blank"),
    wordBank("compost | contamination | conservation | crop rotation | sustainable"),
    sp(80),
    ...fillBlanks([
      "Adding _____________ to soil improves it by adding nutrients from decayed material.",
      "_____________ means planting different crops each season to keep the soil healthy.",
      "_____________ of soil happens when chemicals or waste get into it and make it unhealthy.",
      "Soil _____________ means protecting soil so it stays healthy for future generations.",
      "Farming in a _____________ way means using methods that don't permanently damage the land.",
    ]),
    sp(160),

    sectionHeader("🗂️","Sort It!"),
    wordBank("Adding compost | Using too many chemicals | Planting trees | Leaving soil bare | Crop rotation | Pouring oil on ground | Reducing erosion | Overwatering"),
    sp(80),
    sortTable(
      "✅ Protects Soil",
      "⚠️ Harms Soil",
      [],[]),
    sp(160),

    sectionHeader("💡","Think About It"),
    thinkBox("Imagine a farm that uses the same crop every year and never adds compost. What problems might happen? What would you suggest the farmer do differently?"),
  ];

  // ══════════════════════════════════════════
  // ANSWER KEY
  // ══════════════════════════════════════════
  const ak=[
    pb(),
    new Table({width:{size:100,type:WidthType.PERCENTAGE},rows:[new TableRow({children:[new TableCell({
      shading:{type:ShadingType.SOLID,color:"333333"},
      borders:{top:border("333333"),bottom:border("333333"),left:border("333333"),right:border("333333")},
      children:[
        new Paragraph({alignment:AlignmentType.CENTER,children:[new TextRun({text:"🔑 Answer Key",bold:true,color:"FFFFFF",size:32})]}),
        new Paragraph({alignment:AlignmentType.CENTER,children:[new TextRun({text:"Teacher Reference Only | Grade 3 Science",color:"FFFFFF",size:20})]})
      ]
    })]})]}),
    sp(160),
    new Table({width:{size:100,type:WidthType.PERCENTAGE},rows:[
      new TableRow({children:[hCell("Section","4a7c4a",30),hCell("Answers","4a7c4a",70)]}),
      answerRow("E1.1 Fill in Blank","1. Soil  2. Society  3. environment  4. oxygen  5. sponge"),
      answerRow("E1.1 Sort","Society: Grows food, Place to build homes, Grows cotton | Environment: Provides oxygen, Home for worms, Filters water"),
      answerRow("E1.2 Fill in Blank","1. minerals  2. humus  3. water, air  4. Microorganisms  5. Humus"),
      answerRow("E1.2 Sort","Non-Living: Tiny rock pieces, Water, Air pockets, Minerals, Sand grains | Living: Worms, Bacteria"),
      answerRow("E2.1 Fill in Blank","1. Clay  2. Sandy  3. Loam  4. texture  5. drainage"),
      answerRow("E2.1 Sort","Clay: Holds water, Sticky when wet, Cracks when dry | Sandy: Drains too fast, Feels gritty, Lets water run through | Loam: Best for growing, Good mix of particles"),
      answerRow("E2.2 Fill in Blank","1. Earthworms  2. decomposers  3. nutrients  4. Aerate  5. habitat"),
      answerRow("E2.2 Sort","Plants: Oak tree, Grass, Dandelion | Animals/Decomposers: Earthworm, Mushroom, Bacteria, Beetle"),
      answerRow("E2.3 Fill in Blank","1. Erosion  2. absorption  3. runoff  4. Permeability  5. flooding"),
      answerRow("E2.3 True/False","1. F  2. T  3. T  4. T  5. F"),
      answerRow("E2.4 Fill in Blank","1. compost  2. Crop rotation  3. Contamination  4. conservation  5. sustainable"),
      answerRow("E2.4 Sort","Protects: Adding compost, Planting trees, Crop rotation, Reducing erosion | Harms: Too many chemicals, Leaving soil bare, Pouring oil, Overwatering"),
    ]}),
  ];

  const doc = new Document({
    styles:{default:{document:{run:{font:"Calibri"}}}},
    sections:[{children:[...cover,...e11,...e12,...e21,...e22,...e23,...e24,...ak]}]
  });

  const blob = await Packer.toBlob(doc);
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href=url; a.download="Soils_in_the_Environment_Worksheets_Grade3.docx";
  a.click(); URL.revokeObjectURL(url);
  document.getElementById("status").textContent="✅ Download started!";
}
</script>
</body>
</html>
